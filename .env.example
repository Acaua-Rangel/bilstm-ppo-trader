# Binance API
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_secret
BINANCE_TESTNET=true

# Trading params
TRADING_SYMBOL=BTC/FDUSD
TRADING_TIMEFRAME=15m
INITIAL_CAPITAL_USD=1000

# Risk — sized for 15m timeframe + 60min model horizon
# Derived from typical BTC 15m ATR(14) ≈ 0.18%
MAX_POSITION_RISK_PCT=0.02
MAX_DAILY_DRAWDOWN_PCT=0.05
STOP_LOSS_PCT=0.0030
TAKE_PROFIT_PCT=0.0050
SLIPPAGE_PCT=0.0005

# Runtime state (entry price / bars-in-position) — persisted across restarts
# so SL/TP anchors survive a restart inside an open position.
STATE_FILE_PATH=.runtime/trading-state.json
