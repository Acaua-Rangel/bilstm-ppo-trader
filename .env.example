# Binance API
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_secret
BINANCE_TESTNET=true

# Trading params
TRADING_SYMBOL=BTC/FDUSD
TRADING_TIMEFRAME=5m
INITIAL_CAPITAL_USD=1000

# Risk — sized for 5m timeframe + 20min model horizon
# Derived from typical BTC 5m ATR(14) ≈ 0.10%
MAX_POSITION_RISK_PCT=0.02
MAX_DAILY_DRAWDOWN_PCT=0.05
STOP_LOSS_PCT=0.0015
TAKE_PROFIT_PCT=0.0025
SLIPPAGE_PCT=0.0005
