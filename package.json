{
  "name": "bilstm-ppo-trader",
  "version": "1.0.0",
  "description": "Trading bot with BiLSTM + PPO following Hexagonal Architecture",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/main.ts",
    "train": "node --max-old-space-size=8192 -r ts-node/register src/main.ts train",
    "train:gpu": "node --max-old-space-size=8192 -r ts-node/register src/main.ts train --device=gpu",
    "train:cpu": "node --max-old-space-size=8192 -r ts-node/register src/main.ts train --device=cpu",
    "test:strategy": "node --max-old-space-size=4096 -r ts-node/register src/main.ts test",
    "test:strategy:gpu": "node --max-old-space-size=4096 -r ts-node/register src/main.ts test --device=gpu",
    "invest": "ts-node src/main.ts invest",
    "lint": "eslint src --ext .ts",
    "setup:cuda": "powershell -ExecutionPolicy Bypass -File scripts/setup-cuda.ps1",
    "train:cuda118": "powershell -ExecutionPolicy Bypass -File scripts/run-with-cuda118.ps1 npm run train:gpu",
    "test:strategy:cuda118": "powershell -ExecutionPolicy Bypass -File scripts/run-with-cuda118.ps1 npm run test:strategy:gpu"
  },
  "dependencies": {
    "@tensorflow/tfjs-node": "^4.17.0",
    "ccxt": "^4.3.0",
    "discrete-wavelets": "^5.0.15",
    "dotenv": "^16.4.0",
    "technicalindicators": "^3.1.0"
  },
  "optionalDependencies": {
    "@tensorflow/tfjs-node-gpu": "^4.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
